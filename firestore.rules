rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      // Create: must have status == 0, players must include creator
      allow create: if request.auth != null 
                    && request.resource.data.status == 0 
                    && request.auth.uid in request.resource.data.participantIds;
      
      // Read: anyone can read waiting rooms, otherwise only participants
      allow read: if request.auth != null 
                  && (resource.data.status == 0 || request.auth.uid in resource.data.participantIds);
      
      // Update: participants can update, OR new players can join a waiting room
      allow update: if request.auth != null 
                    && (
                      // Existing participant updating the game
                      (request.auth.uid in resource.data.participantIds
                       && request.resource.data.gameId == resource.data.gameId)
                      ||
                      // New player joining a waiting room (status == 0)
                      (resource.data.status == 0
                       && request.auth.uid in request.resource.data.participantIds
                       && request.resource.data.status == 0
                       && request.resource.data.gameId == resource.data.gameId)
                    );
      
      allow delete: if false;

      match /hands/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
